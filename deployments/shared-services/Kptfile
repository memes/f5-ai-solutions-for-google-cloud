apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: shared-services
  annotations:
    config.kubernetes.io/local-config: "true"
    community.f5.com/demo-source: https://github.com/memes/f5-ai-solutions-for-google-cloud
    community.f5.com/email: m.emes@f5.com
    community.f5.com/owner: emes
info:
  description: |-
    Provides a common set of shared services for a cluster:
      * A shared Gateway instance for the cluster
      * A service account with access to postgres server
  emails:
    - m.emes@f5.com
  license: Apache-2.0
  keywords:
    - gateway
    - shared
pipeline:
  mutators:
    - image: ghcr.io/kptdev/krm-functions-catalog/apply-setters:latest
      configMap:
        shared-services-gateway-address: ai-demo-gke-gw-us-ce1-pub
        shared-services-gateway-f5-ai-host: f5-ai.strangelambda.com
        shared-services-gateway-cert-manager-id: ai-demo-us-ce1
        shared-services-gateway-ssl-policy: ai-demo-us-ce1
    - image: ghcr.io/kptdev/krm-functions-catalog/set-namespace:latest
      configPath: package-context.yaml
    - image: ghcr.io/kptdev/krm-functions-catalog/set-annotations:latest
      configPath: set-annotations.yaml
  validators:
    - image: ghcr.io/kptdev/krm-functions-catalog/kubeconform:latest
      configMap:
        strict: 'true'

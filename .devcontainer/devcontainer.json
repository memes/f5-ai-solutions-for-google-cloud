{
    "name": "memes-f5-ai-solutions-for-google-cloud",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "none",
            "helm": "latest",
            "minikube": "none"
        },
        "ghcr.io/memes/devcontainers-features/direnv:1": {},
        "ghcr.io/memes/devcontainers-features/hashicorp:1": {
            "terraform": "1.5.7"
        },
        "ghcr.io/memes/devcontainers-features/gcrane:1": {},
        "ghcr.io/memes/devcontainers-features/google-cloud-cli:1": {
            "components": "kpt kubectl kustomize gke-gcloud-auth-plugin skaffold",
            "installFromTarball": true
        },
        "ghcr.io/memes/devcontainers-features/opentofu:1": {
            "version": "1.11.4"
        },
        "ghcr.io/memes/devcontainers-features/starship:1": {},
        "ghcr.io/memes/devcontainers-features/talisman:1": {
            "version": "1.37.0"
        },
        "ghcr.io/memes/devcontainers-features/terraform-docs:1": {
            "version": "0.21.0"
        },
        "ghcr.io/memes/devcontainers-features/tflint:1": {
            "version": "0.60.0"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "Gruntfuggly.todo-tree",
                "redhat.vscode-yaml",
                "streetsidesoftware.code-spell-checker",
                "opentofu.vscode-opentofu",
                "esbenp.prettier-vscode",
                "DavidAnson.vscode-markdownlint",
                "hashicorp.hcl",
                "ms-kubernetes-tools.vscode-kubernetes-tools"
            ]
        }
    },
    "containerUser": "vscode",
    "updateRemoteUserUID": true,
    "mounts": [
        "source=${localEnv:HOME}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind,consistency=cached",
        "source=${localEnv:HOME}/projects/oss/terraform-google-private-gke-cluster,target=/home/vscode/terraform-google-private-gke-cluster,type=bind,consistency=cached",
        "source=${localEnv:HOME}/projects/automation/google-demo-helper-modules,target=/home/vscode/google-demo-helper-modules,type=bind,consistency=cached"

    ],
    "onCreateCommand": {
        "install-deps": "sudo sh -c 'apt update && apt install -y --no-install-recommends shellcheck netcat-openbsd postgresql-client-15 && rm -rf /var/lib/apt/lists/*'",
        "install-pre-commit": ["/usr/local/py-utils/bin/pipx", "install", "pre-commit"],
        "modify-default-omz-plugins": ["/usr/bin/sed", "-i.onCreateCommand" , "-e", "/^plugins=/c\\plugins=(git dotenv)", "/home/vscode/.zshrc"]
    },
    "postCreateCommand": {
        "config-pre-commit": "pre-commit install --hook-type commit-msg --hook-type pre-commit"
    }
}

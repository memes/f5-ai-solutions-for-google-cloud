{
    "name": "memes-f5-ai-solutions-for-google-cloud",
    "image": "mcr.microsoft.com/devcontainers/base:debian",
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false
        },
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "none",
            "helm": "latest",
            "minikube": "none"
        },
        "ghcr.io/memes/devcontainers-features/direnv:1": {},
        "ghcr.io/memes/devcontainers-features/hashicorp:1": {
            "terraform": "1.5.7"
        },
        "ghcr.io/memes/devcontainers-features/gcrane:1": {},
        "ghcr.io/memes/devcontainers-features/google-cloud-cli:1": {
            "components": "kpt kubectl gke-gcloud-auth-plugin skaffold"
        },
        "ghcr.io/memes/devcontainers-features/opentofu:1": {
            "version": "1.11.6"
        },
        "ghcr.io/memes/devcontainers-features/starship:1": {},
        "ghcr.io/memes/devcontainers-features/talisman:1": {
            "version": "1.37.0"
        },
        "ghcr.io/memes/devcontainers-features/terraform-docs:1": {
            "version": "0.22.0"
        },
        "ghcr.io/memes/devcontainers-features/tflint:1": {
            "version": "0.62.0"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "Gruntfuggly.todo-tree",
                "redhat.vscode-yaml",
                "streetsidesoftware.code-spell-checker",
                "opentofu.vscode-opentofu",
                "esbenp.prettier-vscode",
                "DavidAnson.vscode-markdownlint",
                "hashicorp.hcl",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-azuretools.vscode-containers"
            ]
        }
    },
    "containerUser": "vscode",
    "containerEnv": {
        "HF_HOME": "/var/lib/hf_cache"
    },
    "updateRemoteUserUID": true,
    "mounts": [
        "source=${localEnv:HOME}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind,consistency=cached",
        "source=hugging-face-cache,target=/var/lib/hf_cache,type=volume"

    ],
    "onCreateCommand": {
        "install-deps": "sudo sh -c 'apt update && apt install -y --no-install-recommends shellcheck kustomize pipx njs && rm -rf /var/lib/apt/lists/*'",
        "modify-default-omz-plugins": ["/usr/bin/sed", "-i.onCreateCommand" , "-e", "/^plugins=/c\\plugins=(git dotenv)", "/home/vscode/.zshrc"]
    },
    "updateContentCommand": {
        "install-pipx-packages": "pipx install pre-commit huggingface_hub"
    },
    "postCreateCommand": {
        "config-pre-commit": "pre-commit install --hook-type commit-msg --hook-type pre-commit"
    }
}
